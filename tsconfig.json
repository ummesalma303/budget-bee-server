{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2023",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "./dist",
        "rootDir": "./",
        "paths": {
            "@/*": ["./src/*"],
            "#generated/*": ["./node_modules/.prisma/client/*"]
        },
        "types": ["node"]
    },
    "include": ["src", "prisma.config.ts", "node_modules/.prisma/client"]
}

