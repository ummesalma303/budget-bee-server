{
    "name": "budget-bee-server",
    "version": "1.0.0",
    "description": "",
    "main": "server.ts",
    "type": "module",
    "scripts": {
        "dev": "tsx --watch --env-file .env.development src/server.ts",
        "dev:staging": "tsx --watch --env-file .env.staging src/server.ts",
        "dev:prod": "tsx --watch --env-file .env.production src/server.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "nodemon dist/server.js",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "test": "vitest",
        "test:run": "vitest run",
        "test:ui": "vitest --ui",
        "coverage": "vitest run --coverage",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,yml,yaml,md}": [
            "prettier --write"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.30.3",
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@types/cors": "^2.8.19",
        "@types/winston": "^2.4.4",
        "bcrypt": "^6.0.0",
        "colorette": "^2.0.20",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "logform": "^2.7.0",
        "morgan": "^1.10.1",
        "npm-check-updates": "^19.6.3",
        "pg": "^8.20.0",
        "rate-limiter-flexible": "^9.1.1",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@eslint/js": "^10.0.1",
        "@tsconfig/node22": "^22.0.5",
        "@tsconfig/node24": "^24.0.4",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.3.5",
        "@types/pg": "^8.18.0",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/eslint-plugin": "^1.6.9",
        "eslint": "^10.0.3",
        "eslint-plugin-perfectionist": "^5.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "prettier": "^3.8.1",
        "prisma": "^7.4.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.18"
    },
    "imports": {
        "#*": "./src/*"
    },
    "volta": {
        "node": "24.13.0"
    }
}
